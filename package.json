{
  "name": "portfolio-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format:check": "npx --yes prettier@3.6.2 --check .",
    "test": "node --test tests/**/*.test.mjs",
    "test:e2e:smoke": "node scripts/e2e-smoke.mjs",
